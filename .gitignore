# Invictus - Git Ignore
# ──────────────────────────────────────────────────────────────────────

# Environment & Secrets
.env
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env/

# RAG & Local Data Vaults
invictus/rag/sec_vault/
invictus/rag/transcripts/
sec-edgar-filings/

# Database files
analytics.db
*.sqlite
*.db

# Data files (keep demo data)
*.csv
*.parquet
*.json
!invictus/data/demo/**/*.json

# FUSE / OS temp files
.fuse_hidden*
*/.fuse_hidden*

# OS & IDE
.DS_Store
**/.DS_Store
.vscode/
.idea/
*.swp
*.bak

